import window
import ui12

ui12.background = "#1e1e2e"
ui12.color = "#cdd6f4"
ui12.fontSize = 28
ui12.fontFamily = "Arial"
ui12.position = "center"
ui12.borderRadius = 8
ui12.buttonBackground = "#89b4fa"
ui12.buttonColor = "#1e1e2e"

show "VezeLang + ui12" in window
show "Стили работают!" in window

on click("Нажми меня") => {
    show "ui12 v0.1 работает!" in window
}
